    {
      "id": "IEV_43NnmhrNE4ZHQXoz2",
      "type": "text",
      "x": 899.8047611165086,
      "y": 1100.2283186845746,
      "width": 693.8195190429688,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b6c",
      "roundness": null,
      "seed": 1138766243,
      "version": 715,
      "versionNonce": 540735917,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1771247562793,
      "link": null,
      "locked": false,
      "text": "Transistor- processer has transistor in million or trillions\n               if current goes in it it will be 1 otherwise 0.\n different different company made their processor with differ\n no of processor and pins. processor has pins in it,if we want\n to communicate with hardware like add 2 num...we give different binary\n to interect with that pins and transistor.if pins levels are differ\nthat its obivious their binary will also matter or canged in hardware lvl.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Transistor- processer has transistor in million or trillions\n               if current goes in it it will be 1 otherwise 0.\n different different company made their processor with differ\n no of processor and pins. processor has pins in it,if we want\n to communicate with hardware like add 2 num...we give different binary\n to interect with that pins and transistor.if pins levels are differ\nthat its obivious their binary will also matter or canged in hardware lvl.",
      "autoResize": true,
      "lineHeight": 1.25
    },
