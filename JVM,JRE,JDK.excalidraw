      "boundElements": null,
      "updated": 1771347654561,
      "link": null,
      "locked": false,
      "text": "In starting it run using interpreter bcz of few earlier problem like hardware slow,ram limited,disk slow\nbut these problem are not occur in modern time .\n\nso we add a JIT compiler with the existing intrepreter.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In starting it run using interpreter bcz of few earlier problem like hardware slow,ram limited,disk slow\nbut these problem are not occur in modern time .\n\nso we add a JIT compiler with the existing intrepreter.",
      "autoResize": true,
      "lineHeight": 1.25
