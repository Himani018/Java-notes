      "updated": 1771520564747,
      "link": null,
      "locked": false,
      "text": "first java check msb of number if its 1 it means it is negative\nthen compiler take its 1's compliment then add 1 for 2's compliment.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "first java check msb of number if its 1 it means it is negative\nthen compiler take its 1's compliment then add 1 for 2's compliment.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
