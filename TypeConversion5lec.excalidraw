      "isDeleted": false,
      "boundElements": null,
      "updated": 1772646969711,
      "link": null,
      "locked": false,
      "text": "50 * 40 =2000 (already out of byte range);\nSo java automatically convert a and be in int before calculating\n2000/100 =200 ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "50 * 40 =2000 (already out of byte range);\nSo java automatically convert a and be in int before calculating\n2000/100 =200 ",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MnzkYGcAWShjoTtEcai3V",
      "type": "text",
      "x": 10936.156574287748,
      "y": 2564.007575127404,
      "width": 346.8197937011719,
      "height": 75,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
