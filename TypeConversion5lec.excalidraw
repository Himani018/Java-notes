      "seed": 1489966927,
      "version": 634,
      "versionNonce": 978314881,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772646969711,
      "link": null,
      "locked": false,
      "text": "Type Promotion Rule->\n1) Byte short and char values are promoted to int in any calculation.\n2)If one operand is long then whole expression is become long in any calculation\n3) If one operand is float ,entire expression will become float.\n4) If one operand is double ,entire expression will be double.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Type Promotion Rule->\n1) Byte short and char values are promoted to int in any calculation.\n2)If one operand is long then whole expression is become long in any calculation\n3) If one operand is float ,entire expression will become float.\n4) If one operand is double ,entire expression will be double.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
