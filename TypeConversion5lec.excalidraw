      "seed": 1471635535,
      "version": 417,
      "versionNonce": 1940579009,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772646969711,
      "link": null,
      "locked": false,
      "text": "In this case java automatically \npromote data type which known as \nautomatic type promotion",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In this case java automatically \npromote data type which known as \nautomatic type promotion",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "nTu_W6LzzBJ0sD8wupetF",
      "type": "text",
      "x": 10545.525600879322,
      "y": 2834.6063792344876,
      "width": 603.9796142578125,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bCq",
      "roundness": null,
      "seed": 1676319969,
      "version": 612,
      "versionNonce": 1956831905,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772646969711,
      "link": null,
      "locked": false,
      "text": "byte b =50;\nb= b*2;\n//here we get compile error;\n first java promote b into int\nnow the 50 is int 50.\n50*2=100 which is also a int\nand when we assign it into b which is byte\nthen we get error.\nso to solve this problem we have to do type casting here too\nb=(byte)b*2;",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "byte b =50;\nb= b*2;\n//here we get compile error;\n first java promote b into int\nnow the 50 is int 50.\n50*2=100 which is also a int\nand when we assign it into b which is byte\nthen we get error.\nso to solve this problem we have to do type casting here too\nb=(byte)b*2;",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "uMpRmZdTKotv1yowPhsr3",
      "type": "text",
      "x": 10541.313959136383,
      "y": 3146.2687945098482,
      "width": 777.5994262695312,
      "height": 150,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
